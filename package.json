    "react-intl": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.4",
    "styled-components": "^6.4.2",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
